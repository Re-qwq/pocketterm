# =============================================================================
# PocketTerm Docker 环境变量配置
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env：  cp .env.example .env
#   2. 根据需要修改下面的配置项
#   3. 启动容器：           docker compose up -d
# =============================================================================

# 运行环境标识
POCKETTERM_ENV=production

# 时区设置（影响日志时间戳）
TZ=Asia/Shanghai

# Web 服务端口（与 docker-compose.yml 中的端口映射配合使用）
# 宿主机端口:容器端口，默认 8000:8000
# 修改此值后需同步修改 docker-compose.yml 的 ports 配置
WEB_PORT=8000
