# =============================================================================
# PocketTerm Docker 构建上下文排除规则
# =============================================================================

# Python 缓存和编译文件
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
.Python
dist/
build/

# Git 版本控制
.git/
.gitignore
.gitattributes

# 数据库文件 (运行时生成, 通过卷挂载持久化)
backend/data/*.db
backend/data/*.db-journal

# 数据 JSON 文件 (运行时生成或敏感数据, 通过卷挂载持久化)
# 例外: device_fingerprints.json 需要打包进镜像
backend/data/*.json
!backend/data/device_fingerprints.json

# 虚拟环境
venv/
.venv/
env/
backend/venv/

# 日志文件
*.log

# Node 依赖
node_modules/

# 截图
screenshots/

# 文档
docs/

# 工具 (Windows 可执行文件, Docker 中不需要)
tools/

# 敏感数据
sauth_batch.json

# IDE 配置
.idea/
.vscode/
*.swp
*.swo

# 环境变量文件 (可能包含敏感信息)
.env
.env.local
.env.production

# Docker 构建文件 (不需要在镜像内)
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore

# 操作系统文件
.DS_Store
Thumbs.db

# Go 构建备份
access_point_go/pocketterm_ap.bak
