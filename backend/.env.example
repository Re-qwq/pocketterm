# PocketTerm 环境配置
# 生产环境必须设置
POCKETTERM_ENV=production
POCKETTERM_JWT_SECRET=your-random-secret-key-here
POCKETTERM_CORS_ORIGINS=https://your-domain.com

# 邮件发送配置 (用户注册验证码)
# 方式一: Resend HTTP API (推荐, 适用于 Railway/Vercel 等 PaaS 平台)
# 免费层: 3000 封/月, 无需域名验证即可使用 onboarding@resend.dev
# 注册: https://resend.com
RESEND_API_KEY=
RESEND_FROM=PocketTerm <onboarding@resend.dev>

# 方式二: SMTP (适用于 VPS/本地部署)
# 注意: Railway 等 PaaS 平台会阻止出站 SMTP 端口 (25/465/587)
# QQ 邮箱 SMTP 配置示例:
#   SMTP_HOST=smtp.qq.com
#   SMTP_PORT=465
#   SMTP_USER=your_qq@qq.com
#   SMTP_PASS=your_auth_code  (QQ邮箱授权码, 非登录密码)
#   SMTP_FROM=your_qq@qq.com
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 开发调试（生产环境不要设置）
# POCKETTERM_DEBUG=1
